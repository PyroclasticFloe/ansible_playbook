[Unit]
Description=VaultWarden
After=network-online.target
Wants=network-online.target

[Container]
Pod=vaultwarden.pod

Image=vaultwarden/server:latest

Volume=/var/lib/local_containers/vaultwarden/data/:/data:Z

Environment=DOMAIN=https://vaultwarden.tail044fe.ts.net/

[Service]
Restart=always

[Install]
WantedBy=multi-user.target
